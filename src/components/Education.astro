---
const courses = [
  'Data Mining',
  'Artificial Intelligence',
  'Machine Learning',
  'Web Data Management',
  'Design & Analysis of Algorithms',
  'Neural Networks',
  'Information Security',
];
---

<section id="education">
  <div class="max-w-5xl mx-auto px-5 sm:px-6">

    <div class="text-center mb-14 reveal">
      <div class="section-label" style="display: inline-flex;">Education</div>
      <h2 class="font-display font-bold text-4xl text-white mb-2 mt-3">Academic Background</h2>
      <div class="section-divider" style="margin-left: auto; margin-right: auto;"></div>
    </div>

    <div class="glass rounded-2xl p-8 sm:p-10 reveal hover:border-sky-400/25 transition-all duration-300">
      <div class="flex flex-wrap items-start justify-between gap-6">
        <div class="flex gap-5 items-start">
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl flex-shrink-0"
            style="background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.2);"
          >
            🎓
          </div>
          <div>
            <h3 class="font-display font-bold text-xl text-white mb-1">MS Computer Science (Thesis)</h3>
            <p class="text-sky-400 font-semibold mb-1">The University of Texas at Arlington</p>
            <p class="text-slate-500 text-sm">Arlington, TX, USA</p>
          </div>
        </div>
        <div>
          <div
            class="px-3 py-1.5 rounded-lg text-sm font-semibold"
            style="background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.2);"
          >
            2021 – 2023
          </div>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-slate-800/60">
        <h4 class="font-display font-semibold text-xs text-slate-400 mb-4 uppercase tracking-widest">
          Relevant Coursework
        </h4>
        <div class="flex flex-wrap gap-2">
          {courses.map(course => (
            <span class="tag tag-purple">{course}</span>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
