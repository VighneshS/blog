    current: false,
    highlights: [
      'Developed Android applications and ML models for research on "Continuous Authentication using Human-Induced Electric Potential" — published at ACSAC 2023.',
      'Organized workshops and contributed to a cloud-based IoT system for real-time water quality monitoring.',
    ],
    tech: ['Android', 'Machine Learning', 'IoT', 'Cloud', 'Signal Processing', 'Security'],
  },
  {
    company: 'Revature, LLC',
    role: 'Senior Software Engineer',
    location: 'Chennai, TN, IND',
    period: '08/2016 – 12/2020',
    current: false,
    highlights: [
      'Led a team of five on the Operations & Management team, overseeing daily production bug fixes and feature delivery.',
      'Developed microservices for web applications using MySQL, Java Spring Boot framework, and Angular.',
      'Managed and improved product infrastructure on AWS and GCP: EC2, RDS, EKS, and Terraform automation scripts.',
    ],
    tech: ['Java Spring', 'Angular', 'MySQL', 'AWS EC2', 'AWS RDS', 'EKS', 'GCP', 'Terraform', 'Docker'],
  },
