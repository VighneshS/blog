---

<section id="experience">
  <div class="max-w-5xl mx-auto px-5 sm:px-6">

    <div class="text-center mb-14 reveal">
      <div class="section-label" style="display: inline-flex;">Career</div>
      <h2 class="font-display font-bold text-4xl text-white mb-2 mt-3">Experience</h2>
      <div class="section-divider" style="margin-left: auto; margin-right: auto;"></div>
    </div>

    <div class="relative">
      <!-- Vertical timeline line -->
      <div
        class="absolute left-4 top-7 bottom-7 w-px hidden sm:block"
        style="background: linear-gradient(180deg, rgba(56,189,248,0.5) 0%, rgba(56,189,248,0.05) 100%);"
      ></div>

      <div class="space-y-8">
        {experiences.map((exp, i) => (
          <div class={`relative sm:pl-14 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <!-- Timeline dot -->
            <div class={`absolute left-0 top-6 w-8 h-8 rounded-full hidden sm:flex items-center justify-center flex-shrink-0 ${exp.current ? 'border-2 border-sky-400' : 'border-2 border-slate-700'}`}
                 style={`background: ${exp.current ? 'rgba(56,189,248,0.12)' : 'rgba(30,41,59,0.8)'};`}>
              <div class={`w-2.5 h-2.5 rounded-full ${exp.current ? 'bg-sky-400 shadow-lg' : 'bg-slate-600'}`}
                   style={exp.current ? 'box-shadow: 0 0 8px rgba(56,189,248,0.8); animation: pulse 2s infinite;' : ''}></div>
            </div>

            <div class="glass rounded-2xl p-6 sm:p-7 hover:border-sky-400/25 transition-all duration-300">
              <!-- Header -->
              <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
                <div>
                  <div class="flex items-center flex-wrap gap-2 mb-1">
                    <h3 class="font-display font-bold text-lg text-white">{exp.role}</h3>
                    {exp.current && (
                      <span class="px-2 py-0.5 rounded-full text-xs font-semibold"
                            style="background: rgba(56,189,248,0.12); color: #38bdf8; border: 1px solid rgba(56,189,248,0.3);">
                        Current
                      </span>
                    )}
                  </div>
                  <p class="text-sky-400 font-semibold text-sm">{exp.company}</p>
                </div>
                <div class="text-right shrink-0">
                  <div class="text-slate-300 text-sm font-medium">{exp.period}</div>
                  <div class="text-slate-500 text-xs mt-0.5">{exp.location}</div>
                </div>
              </div>

              <!-- Bullet points -->
              <ul class="space-y-2.5 mb-5">
                {exp.highlights.map(point => (
                  <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                    <span class="text-sky-500 mt-1 flex-shrink-0 text-xs">▸</span>
                    {point}
                  </li>
                ))}
              </ul>

              <!-- Tech tags -->
              <div class="flex flex-wrap gap-1.5 pt-4 border-t border-slate-800/60">
                {exp.tech.map(t => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
