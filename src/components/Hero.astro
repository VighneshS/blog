---
import { yearsExp } from '../lib/experience';
const base = import.meta.env.BASE_URL;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-grid">
  <!-- Ambient glows -->
  <div class="absolute -top-40 -left-40 w-[700px] h-[700px] rounded-full blur-3xl pointer-events-none"
       style="background: radial-gradient(circle, rgba(29,78,216,0.18) 0%, transparent 70%);"></div>
  <div class="absolute -bottom-40 -right-40 w-[600px] h-[600px] rounded-full blur-3xl pointer-events-none"
       style="background: radial-gradient(circle, rgba(124,58,237,0.14) 0%, transparent 70%);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center py-28 lg:py-32">

      <!-- Text content -->
      <div class="order-2 lg:order-1">
        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-semibold mb-7"
             style="background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.25); color: #7dd3fc;">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Available for opportunities
        </div>

        <!-- Name -->
        <h1 class="font-display font-bold leading-none mb-4" style="font-size: clamp(3rem, 8vw, 5rem);">
          <span class="block text-white">Vighnesh</span>
          <span class="block grad">Sivaraman</span>
        </h1>

        <!-- Role pills -->
        <div class="flex flex-wrap sm:flex-nowrap items-center gap-2 mb-5">
          <span class="text-slate-300 font-semibold text-base">Senior Software Engineer</span>
          <span class="text-slate-600 text-lg">·</span>
          <span class="text-slate-400 font-medium text-base">AI/ML &bull; Full-Stack</span>
          <span class="text-slate-600 text-lg">·</span>
          <span class="text-slate-400 font-medium text-base">AWS &middot; GCP &middot; Azure</span>
        </div>

        <!-- Tagline -->
        <p class="text-slate-500 text-base sm:text-lg leading-relaxed max-w-lg mb-10">
          Building AI-powered enterprise platforms and cloud-native systems.
          {yearsExp}+ years shipping production software across India and the US.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-3 mb-10">
          <a
            href="#experience"
            class="px-7 py-3 rounded-xl font-semibold text-sm text-white transition-all duration-200 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #0284c7, #4f46e5); box-shadow: 0 4px 24px rgba(2,132,199,0.3);"
          >
            View My Work
          </a>
          <a
            href={`${base}/docs/Vighnesh_Sivaraman_Resume.pdf`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-7 py-3 rounded-xl font-semibold text-sm text-slate-300 border border-slate-700 hover:border-sky-500/50 hover:text-sky-400 transition-all duration-200"
          >
            Download Resume
          </a>
          <a
            href="#contact"
            class="px-7 py-3 rounded-xl font-semibold text-sm text-slate-300 border border-slate-700 hover:border-sky-500/50 hover:text-sky-400 transition-all duration-200"
          >
            Get In Touch
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-5">
          <a href="https://github.com/VighneshS" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
            </svg>
          </a>
          <a href="https://linkedin.com/in/vighnesh-sivaraman" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://x.com/jeevavighnesh" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="X / Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="mailto:jeevavignesh@gmail.com" class="social-icon" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
          <div class="h-4 w-px bg-slate-700 mx-1"></div>
          <span class="text-slate-600 text-xs font-medium">West Tambaram, Chennai, India</span>
        </div>
      </div>

      <!-- Profile photo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Glow ring -->
          <div class="absolute inset-0 rounded-3xl blur-2xl pointer-events-none"
               style="background: linear-gradient(135deg, rgba(2,132,199,0.25), rgba(79,70,229,0.25)); transform: scale(1.12);"></div>

          <!-- Photo -->
          <div class="relative rounded-3xl overflow-hidden"
               style="width: clamp(220px, 35vw, 320px); height: clamp(220px, 35vw, 320px); border: 1.5px solid rgba(56,189,248,0.3); box-shadow: 0 30px 70px rgba(0,0,0,0.6);">
            <img
              src={`${base}/images/profile_dp.JPG`}
              alt="Vighnesh Sivaraman"
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
          </div>

          <!-- Stats pill -->
          <div class="absolute -bottom-5 -left-6 glass rounded-xl px-4 py-2.5 text-center">
            <div class="font-display font-bold text-sky-400 text-2xl leading-none">{yearsExp}+</div>
            <div class="text-slate-400 text-xs mt-0.5">Years Exp.</div>
          </div>

          <!-- Open badge -->
          <div class="absolute -top-4 -right-4 glass rounded-xl px-3 py-2 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-medium text-slate-300">Open to Work</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="flex justify-center pb-8">
      <a href="#about" class="flex flex-col items-center gap-2 text-slate-600 hover:text-sky-400 transition-colors">
        <span class="text-xs uppercase tracking-[0.15em] font-medium">Scroll</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
