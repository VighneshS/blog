---
const base = import.meta.env.BASE_URL;
const links = [
  { href: '#about',        label: 'About'      },
  { href: '#skills',       label: 'Skills'     },
  { href: '#experience',   label: 'Experience' },
  { href: '#projects',     label: 'Projects'   },
  { href: '#education',    label: 'Education'  },
  { href: '#publications', label: 'Research'   },
  { href: '#contact',      label: 'Contact'    },
  { href: 'https://vighnesh-studies.blogspot.com', label: 'Blog', external: true },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-5 sm:px-6">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="#hero" class="font-display font-bold text-lg text-white flex items-center gap-2">
        <span
          class="w-7 h-7 rounded-lg flex items-center justify-center text-white text-sm font-bold"
          style="background: linear-gradient(135deg, #0284c7, #4f46e5);"
        >V</span>
        <span class="text-slate-300">ighnesh<span class="text-sky-400">.</span></span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-7" role="list">
        {links.map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              data-section={external ? undefined : href.slice(1)}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class={`nav-link text-sm font-medium text-slate-400 hover:text-sky-400 transition-colors duration-200 relative${external ? ' flex items-center gap-1' : ''}`}
            >
              {label}
              {external && <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}
            </a>
          </li>
        ))}
      </ul>

      <!-- Resume + mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href={`${base}/docs/Vighnesh_Sivaraman_Resume.pdf`}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg border text-sm font-semibold transition-all"
          style="border-color: rgba(56,189,248,0.4); color: #38bdf8;"
          onmouseover="this.style.background='rgba(56,189,248,0.08)'"
          onmouseout="this.style.background=''"
        >
          Resume
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>

        <button id="menu-toggle" class="lg:hidden text-slate-400 hover:text-white transition-colors p-1" aria-label="Toggle menu">
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-nav" class="lg:hidden hidden pb-5 pt-2 border-t border-slate-800/50">
      <ul class="flex flex-col gap-1" role="list">
        {links.map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class="block py-2.5 px-2 text-slate-400 hover:text-sky-400 transition-colors text-sm font-medium mobile-nav-link"
            >
              {label}{external && ' ↗'}
            </a>
          </li>
        ))}
        <li class="pt-2 border-t border-slate-800/50 mt-2">
          <a
            href={`${base}/docs/Vighnesh_Sivaraman_Resume.pdf`}
            target="_blank"
            rel="noopener noreferrer"
            class="block py-2.5 px-2 text-sky-400 text-sm font-semibold mobile-nav-link"
          >
            Resume ↗
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  #site-header { background: transparent; }
  #site-header.scrolled {
    background: rgba(7, 11, 26, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(56,189,248,0.1);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #38bdf8, #818cf8);
    border-radius: 1px;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after,
  .nav-link.active::after { width: 100%; }
  .nav-link.active { color: #38bdf8; }
</style>

<script>
  const header = document.getElementById('site-header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  let open = false;
  menuToggle?.addEventListener('click', () => {
    open = !open;
    mobileNav?.classList.toggle('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      mobileNav?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  const sectionObs = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-section') === entry.target.id);
          });
        }
      });
    },
    { threshold: 0.35, rootMargin: '-80px 0px -40% 0px' }
  );
  sections.forEach(s => sectionObs.observe(s));
</script>
