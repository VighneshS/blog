---
const year = new Date().getFullYear();
---

<footer class="border-t py-10" style="border-color: rgba(56,189,248,0.1); background: var(--bg);">
  <div class="max-w-7xl mx-auto px-5 sm:px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-5">

      <!-- Logo -->
      <a href="#hero" class="flex items-center gap-2 font-display font-semibold text-white">
        <span
          class="w-7 h-7 rounded-lg flex items-center justify-center text-white text-sm font-bold"
          style="background: linear-gradient(135deg, #0284c7, #4f46e5);"
        >V</span>
        Vighnesh Sivaraman
      </a>

      <!-- Credit -->
      <p class="text-slate-600 text-xs text-center">
        &copy; {year} Vighnesh Sivaraman &mdash; Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-sky-400 transition-colors">Astro</a>
        &amp;
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-sky-400 transition-colors">Tailwind CSS</a>
      </p>

      <!-- Links -->
      <div class="flex items-center gap-5">
        <a href="https://github.com/VighneshS" target="_blank" rel="noopener noreferrer"
           class="text-slate-500 hover:text-sky-400 transition-colors text-sm">GitHub</a>
        <a href="https://linkedin.com/in/vighnesh-sivaraman" target="_blank" rel="noopener noreferrer"
           class="text-slate-500 hover:text-sky-400 transition-colors text-sm">LinkedIn</a>
        <a href="mailto:jeevavignesh@gmail.com"
           class="text-slate-500 hover:text-sky-400 transition-colors text-sm">Email</a>
      </div>

    </div>
  </div>
</footer>
