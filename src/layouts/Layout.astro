---
import { yearsExp } from '../lib/experience';
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vighnesh Sivaraman | Senior Software Engineer',
  description = `Senior Software Engineer with ${yearsExp}+ years experience building AI-powered enterprise solutions, cloud-native architectures, and ML systems across AWS, GCP & Azure. Based in West Tambaram, Chennai, India.`,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Vighnesh Sivaraman" />
    <meta name="keywords" content="Vighnesh Sivaraman, Software Engineer, ML Engineer, AI, Machine Learning, West Tambaram, Chennai, TypeScript, Python, AWS, GCP, Azure, React" />
    <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vighneshs.github.io/blog" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@jeevavighnesh" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <style is:global>
      :root {
        --bg:      #070b1a;
        --bg2:     #0c1428;
        --card:    rgba(12, 20, 40, 0.75);
        --border:  rgba(56, 189, 248, 0.18);
        --accent:  #38bdf8;
        --accent2: #818cf8;
        --accent3: #34d399;
        --text:    #e2e8f0;
        --muted:   #64748b;
      }

      html, body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
      }

      body { overflow-x: hidden; }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: rgba(56,189,248,0.35); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
      ::selection { background: rgba(56,189,248,0.25); }

      /* Scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.65s ease, transform 0.65s ease;
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }
      .reveal-delay-4 { transition-delay: 0.4s; }

      /* Gradient text */
      .grad {
        background: linear-gradient(135deg, #38bdf8 0%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Glass card */
      .glass {
        background: var(--card);
        border: 1px solid var(--border);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }

      /* Section layout */
      section { padding: 6rem 0; }
      @media (max-width: 768px) { section { padding: 4rem 0; } }

      /* Section label */
      .section-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border: 1px solid rgba(56,189,248,0.25);
        border-radius: 99px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.75rem;
      }

      /* Skill tags */
      .tag {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.55rem;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 500;
        background: rgba(56,189,248,0.08);
        border: 1px solid rgba(56,189,248,0.2);
        color: #93c5fd;
        transition: all 0.2s;
        white-space: nowrap;
      }
      .tag:hover { background: rgba(56,189,248,0.15); border-color: rgba(56,189,248,0.4); }

      .tag-purple { background: rgba(129,140,248,0.08); border-color: rgba(129,140,248,0.2); color: #c4b5fd; }
      .tag-purple:hover { background: rgba(129,140,248,0.15); }

      .tag-green { background: rgba(52,211,153,0.08); border-color: rgba(52,211,153,0.2); color: #6ee7b7; }
      .tag-green:hover { background: rgba(52,211,153,0.15); }

      .tag-orange { background: rgba(251,146,60,0.08); border-color: rgba(251,146,60,0.2); color: #fdba74; }
      .tag-orange:hover { background: rgba(251,146,60,0.15); }

      .tag-pink { background: rgba(244,114,182,0.08); border-color: rgba(244,114,182,0.2); color: #f9a8d4; }
      .tag-pink:hover { background: rgba(244,114,182,0.15); }

      /* Background grid */
      .bg-grid {
        background-image:
          linear-gradient(rgba(56,189,248,0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(56,189,248,0.04) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Divider */
      .section-divider {
        width: 48px;
        height: 3px;
        background: linear-gradient(90deg, #38bdf8, #818cf8);
        border-radius: 2px;
        margin: 0.75rem 0 2.5rem;
      }

      /* Social icon */
      .social-icon {
        color: #475569;
        transition: color 0.2s, transform 0.2s;
      }
      .social-icon:hover { color: #38bdf8; transform: translateY(-2px); }
    </style>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
    <script>
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    </script>
  </body>
</html>
